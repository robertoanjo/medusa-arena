# ── Supabase (frontend — público) ──────────────────────────────────────────────
# Supabase → Settings → API Keys → Publishable key
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_COLE_SUA_CHAVE_AQUI

# ── Supabase (API Routes — secreto, só no Vercel) ───────────────────────────────
# Supabase → Settings → API Keys → Secret key
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_COLE_SUA_CHAVE_AQUI

# Supabase → Settings → Database → Connection string (Session mode, porta 5432)
DATABASE_URL=postgresql://postgres.SEU-PROJETO:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
