# Supabase → Settings → Database → Connection string (URI)
# Formato: postgresql://postgres.XXXXX:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.XXXXX:YOUR_PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Porta local (Railway define automaticamente)
PORT=3001
